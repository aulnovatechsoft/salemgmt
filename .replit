modules = ["nodejs-20", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BSNL App"

[[workflows.workflow]]
name = "BSNL App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EXPO_NO_TELEMETRY=1 bunx expo export --platform web --output-dir dist && bun run server.ts"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bun", "run", "server.ts"]
build = ["bun", "run", "bunx", "expo", "export", "--platform", "web"]

[userenv]

[userenv.shared]
BSNL_DATABASE_URL = "postgresql://salesmgmt:Bsnl%40123@117.251.72.195:5433/salesmgmt_bsnl?sslmode=disable"
EXPO_PUBLIC_API_URL = "http://117.251.72.195"
